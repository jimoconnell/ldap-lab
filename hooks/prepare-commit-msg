#!/bin/sh
# Strip "Co-authored-by: Cursor <cursoragent@cursor.com>" from commit messages.
# Install: cp hooks/prepare-commit-msg .git/hooks/prepare-commit-msg && chmod +x .git/hooks/prepare-commit-msg
msg_file="$1"
[ -f "$msg_file" ] || exit 0
tmp=$(mktemp) && grep -v '^Co-authored-by: Cursor <cursoragent@cursor.com>$' "$msg_file" >"$tmp" && mv "$tmp" "$msg_file"
exit 0
